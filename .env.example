NODE_ENV=development
PORT=4000
DESKTOP_MODE=false
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=replace-with-a-long-random-string
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key
DATABASE_PATH=./data/playlist-transfer.db

# Spotify app settings
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:4000/api/auth/spotify/callback

# Google OAuth client for YouTube Data API v3
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/youtube/callback

# Transfer tuning
MATCH_CONFIDENCE_THRESHOLD=0.72
TRANSFER_BATCH_SIZE=20
TRANSFER_BATCH_DELAY_MS=1200
MAX_RETRY_ATTEMPTS=4
